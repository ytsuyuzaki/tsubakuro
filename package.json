{
  "name": "tsubakuro",
  "version": "0.0.1",
  "private": true,
  "description": "WordPress task management plugin",
  "license": "GPL-2.0-or-later",
  "files": [
    "tsubakuro.php",
    "includes",
    "admin",
    "public",
    "templates"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@wordpress/e2e-test-utils-playwright": "^1.45.0",
    "@wordpress/env": "^11.5.0",
    "@wordpress/scripts": "^32.1.0"
  },
  "scripts": {
    "lint": "npm run lint:css && npm run lint:js && npm run lint:md:docs && npm run lint:pkg-json && npm run lint:php",
    "format": "wp-scripts format",
    "packages-update": "wp-scripts packages-update",
    "check-engines": "wp-scripts check-engines",
    "check-licenses": "wp-scripts check-licenses",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "lint:js:fix": "wp-scripts lint-js --fix",
    "lint:md:docs": "wp-scripts lint-md-docs",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "lint:php": "vendor/bin/phpcs",
    "lint:php:fix": "vendor/bin/phpcbf",
    "wp-env:test": "wp-env run tests-cli --env-cwd='wp-content/plugins/tsubakuro/' sh -c 'wp plugin activate mcp-adapter >/dev/null 2>&1 || true; vendor/bin/phpunit && vendor/bin/phpunit -c phpunit-integration.xml.dist'",
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:destroy": "wp-env destroy",
    "mcp:connection:test": "node scripts/test-mcp-adapter-connection.mjs",
    "test:e2e": "wp-scripts test-playwright",
    "build:zip": "wp-scripts plugin-zip && mkdir -p dist && mv tsubakuro.zip dist/"
  },
  "overrides": {
    "@wp-playground/blueprints": {
      "ajv": "^8.20.0"
    },
    "@wp-playground/cli": {
      "ajv": "^8.20.0"
    },
    "@wp-playground/tools": {
      "ajv": "^8.20.0"
    },
    "serialize-javascript": "^7.0.5",
    "markdownlint-cli": "^0.48.0",
    "webpack-dev-server": "^5.2.3",
    "uuid": "^14.0.0"
  }
}